# cosmolex-mcp — ProfitSolv LCS /v1 Integration API (scoped OAuth)
#
# Prefer `cosmolex-mcp-setup`, which stores these in your OS keyring and runs the
# one-time OAuth consent. This file is the 0600 fallback when no keyring backend is
# available. NEVER commit real values.

# The integration's API key (sent as the X-Api-Key header).
COSMOLEX_API_KEY=your-lcs-app-api-key

# The OAuth app's client credentials (used for the code exchange + token refresh).
COSMOLEX_CLIENT_ID=ci-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COSMOLEX_CLIENT_SECRET=your-oauth-client-secret

# The redirect URI registered on the OAuth app (consent uses a manual code paste).
COSMOLEX_REDIRECT_URI=https://localhost:8770/callback

# Optional host overrides:
#   COSMOLEX_BASE_URL      — OAuth host (consent + token). Sandbox:
#                            https://sandbox.cosmolex.com (default).
#                            Production: https://law.cosmolex.com
#   COSMOLEX_API_BASE_URL  — LCS /v1 data host. Defaults to the ProfitSolv Azure
#                            sandbox host; set the per-firm production data host here.
# COSMOLEX_BASE_URL=https://sandbox.cosmolex.com

# Set to 0 to opt out of the OS keyring and use the 0600 .env file instead.
# COSMOLEX_MCP_USE_KEYRING=1
