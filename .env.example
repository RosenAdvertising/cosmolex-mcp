# NextGen session login — your CosmoLex web-app username (email) + password.
COSMOLEX_USERNAME=your@email.com
COSMOLEX_PASSWORD=your-password
# Optional host override. Default: https://app.cosmolex.com
# Use https://sandbox.cosmolex.com for the sandbox/trial account.
COSMOLEX_BASE_URL=https://app.cosmolex.com
# Set to 0 to opt out of the OS keyring and use the 0600 .env file instead.
COSMOLEX_MCP_USE_KEYRING=1
